// ============================================================================
//  .vscode/settings.json  —  リポジトリ直下の .vscode/ に保存してコミットする
//  目的: Copilot / エージェントの「安全寄りの共通デフォルト」をチームに配布する
//
//  【重要・必ず読むこと】これは "強制(enforcement)" ではなく "ガードレール" です
//   - ユーザーはこのファイルを編集でき、User設定で上書きできる項目もあります
//   - 確実に変更禁止にしたい設定は、ワークスペース設定ではなくエンタープライズ
//     ポリシー(GPO/ADMX、または Copilot アカウントポリシー)が必要です
//   - 一部のセキュリティ設定は user / machine / org スコープのため、このファイル
//     (ワークスペース)では効きません。→ 末尾の「(参考)User設定/ポリシーに入れる項目」を参照
//   - .vscode/settings.json は JSONC として読まれるため、この // コメントは有効です
//
//  運用メモ: 反映されたかは「設定」を開き、ワークスペースタブで各設定が
//            適用表示になっているかを確認すること(無視される設定は表示されない)。
// ============================================================================
{
  // --------------------------------------------------------------------------
  // 1) 機微ファイルの「エージェントによる編集」を自動承認しない【ワークスペースで有効・最重要】
  //    false = 自動承認しない(必ず手動確認)。秘密情報・インフラ定義の事故防止に最も効く。
  //    必要に応じてプロジェクト固有のパスを追記すること。
  // --------------------------------------------------------------------------
  "chat.tools.edits.autoApprove": {
    "**/.env": false,
    "**/.env.*": false,
    "**/*.pem": false,
    "**/*.key": false,
    "**/*.pfx": false,
    "**/*.p12": false,
    "**/id_rsa": false,
    "**/id_rsa.*": false,
    "**/secrets/**": false,
    "**/.aws/**": false,
    "**/.ssh/**": false,
    "**/credentials": false,
    "**/credentials.*": false,
    "**/appsettings*.json": false,
    "**/*.tfstate": false,
    "**/*.tfvars": false,
    "**/Dockerfile": false,
    "**/docker-compose*.yml": false,
    "**/docker-compose*.yaml": false,
    "**/.github/workflows/**": false,
    "**/.gitlab-ci.yml": false
  },

  // --------------------------------------------------------------------------
  // 2) 破壊的ターミナルコマンドのガードレール
  //    false = 自動承認させない(手動確認)。true = その読み取り系のみ自動承認。
  //    既定ではサブコマンド単位で照合され、自動承認には全サブコマンドが true 一致かつ
  //    false 不一致である必要がある(deny が優先)。
  //
  //    ★注意1: ここの deny は chat.tools.global.autoApprove が OFF のときだけ有効。
  //            ON にされると無視されます(global 無効化は User設定/ポリシー側で行う・末尾参照)。
  //    ★注意2: この設定は環境により user/machine スコープ扱いとなり、ワークスペースでは
  //            効かない場合があります。効かない場合は同じ内容を各自の User設定に入れること。
  //    ★方針:  最大限の厳格運用にしたい場合は、下の true 群を削除して全コマンド手動承認にする。
  // --------------------------------------------------------------------------
  "chat.tools.terminal.autoApprove": {
    // --- 安全な読み取り系のみ自動承認(任意。厳格運用ならこの群ごと削除可) ---
    "/^git\\s+(status|diff|log|show|branch)\\b/": true,
    "/^npm\\s+(test|run\\s+lint)\\b/": true,
    "/^pnpm\\s+(test|lint)\\b/": true,
    "ls": true,

    // --- 破壊的・危険なコマンドは常に手動承認(deny) ---
    "rm": false,
    "rmdir": false,
    "del": false,
    "mv": false,
    "kill": false,
    "chmod": false,
    "chown": false,
    "curl": false,
    "wget": false,
    "eval": false,
    "cat": false,
    "/^Remove-Item\\b/i": false,
    "/^Invoke-WebRequest\\b/i": false,
    "/^git\\s+(push|reset|revert|clean|checkout)\\b/": false,
    "/^npm\\s+(publish|install\\s+-g)\\b/": false,
    "/dangerous/": false
  },

  // --------------------------------------------------------------------------
  // 3) 自律実行を暴走させない(連続実行回数の上限。既定はおおむね 15〜25)
  //    大きくしすぎないこと。金融ドメインでは小さめ推奨。
  // --------------------------------------------------------------------------
  "chat.agent.maxRequests": 25,

  // --------------------------------------------------------------------------
  // 4) エディタ側でも機微ファイルを保護する追加防御(=人間の不用意な手編集を防ぐ)
  //    上記 1) はエージェント編集の保護、こちらはエディタ上の手編集の保護。両者で多層化。
  //    ※エディタ上の読み取り専用化であり、コマンドで一時解除は可能。
  // --------------------------------------------------------------------------
  "files.readonlyInclude": {
    "**/.env": true,
    "**/.env.*": true,
    "**/*.pem": true,
    "**/*.key": true,
    "**/secrets/**": true
  }

  // --------------------------------------------------------------------------
  // (参考)ここに書いても効かない/弱い設定 → User設定 または ポリシーで対応すること
  //
  //  ▼ 各自の User設定(Preferences: Open User Settings (JSON))に入れる:
  //     "chat.tools.global.autoApprove": false,          // 全ツール一括自動承認を無効(グローバル設定)
  //     "security.workspace.trust.enabled": true,        // 未信頼フォルダは制限モード=エージェント無効
  //     "chat.tools.terminal.sandbox.enabled": true,     // ★macOS/Linux/WSL2 のみ有効。Windowsネイティブでは無効
  //     "chat.mcp.discovery.enabled": false,             // 他ツールからのMCP自動検出を抑止
  //
  //  ▼ 本当に「変更禁止」にしたい場合(IT/セキュリティ部門に依頼):
  //     ・VS Code エンタープライズポリシー ChatToolsAutoApprove = false
  //       → chat.tools.global.autoApprove を組織レベルで false にロックし、
  //         権限ピッカーから Bypass Approvals / Autopilot を非表示にする
  //     ・MCP アクセス制御や許可拡張も ADMX / アカウントポリシーでロック可能
  //     ・Dev Tunnels の匿名アクセス無効化ポリシーも併用(自動承認との併用はRCEリスク)
  // --------------------------------------------------------------------------
}
